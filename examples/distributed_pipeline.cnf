IDENTIFICATION DIVISION.
    PROGRAM-ID "distributed-pipeline-v0.6.0".

ENVIRONMENT DIVISION.
    OS "Linux".
    ARCH "x86_64".

NETWORK DIVISION.
    NODE "node1" AT "127.0.0.1:7000".
    NODE "node2" AT "127.0.0.1:7001".
    NODE "node3" AT "127.0.0.1:7002".
    SELF "node1".
    TOPOLOGY PIPELINE.
    TIMEOUT 5000.

DATA DIVISION.
    VIDEO-MP4 INPUT_STREAM AS "input.mp4".
    VIDEO-MP4 STAGE1_DATA.
    VIDEO-MP4 STAGE2_DATA.
    IMAGE-JPG FINAL_OUTPUT.
    BINARY-BLOB CHECKPOINT_DATA.

PROCEDURE DIVISION.
    COMPRESS INPUT_STREAM.
    
    SEND STAGE1_DATA TO "node2".
    
    RECEIVE STAGE2_DATA FROM "node3".
    
    PIPE STAGE2_DATA TO "node3" FINAL_OUTPUT.
    
    CHECKPOINT CHECKPOINT_DATA.
    
    VERIFY-INTEGRITY FINAL_OUTPUT.
